**/linux/flutter/ephemeral/

# Windows related
**/windows/flutter/ephemeral/

# Web related
**/web/*.js.map

# Coverage
coverage/

# Symbols
app.*.symbols

# Exceptions to above rules.
!**/ios/**/default.mode1v3
!**/ios/**/default.mode2v3
!**/ios/**/default.pbxuser
!**/ios/**/default.perspectivev3
!/dev/ci/**/Gemfile.lock

# Aider / editor tooling artifacts (not part of the app)
.aider*
